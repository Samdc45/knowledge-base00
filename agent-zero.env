# Agent Zero Configuration File
# Complete setup for Agent0 with LMS integration

# Basic Configuration
AGENT_NAME=Agent Zero
AGENT_VERSION=v1.3
ENVIRONMENT=production

# Network Configuration
CHAT_NETWORK=chat-network
INTERNAL_PORT=80
EXTERNAL_PORT=55015

# LMS Integration (Knowledge Base)
LMS_URL=http://south-lms:6000
LMS_HEALTH_CHECK=http://south-lms:6000/health
LMS_COURSES_ENDPOINT=http://south-lms:6000/api/courses

# AI Model Configuration
# Choose ONE of the following:

# Option 1: Local Model (FREE - No API Key Needed)
LLM_PROVIDER=ollama
OLLAMA_MODEL=mistral
OLLAMA_BASE_URL=http://ollama:11434

# Option 2: OpenRouter (Requires API Key)
# LLM_PROVIDER=openrouter
# OPENROUTER_API_KEY=your-key-here
# OPENROUTER_MODEL=openrouter/auto

# Option 3: OpenAI (Requires API Key)
# LLM_PROVIDER=openai
# OPENAI_API_KEY=your-key-here
# OPENAI_MODEL=gpt-4

# Memory & Knowledge Base
MEMORY_ENABLED=true
BACKGROUND_KNOWLEDGE=true
KNOWLEDGE_SOURCE=LMS_SERVICE

# Logging Configuration
LOG_LEVEL=INFO
LOG_FORMAT=json
ENABLE_AUDIT_LOGS=true

# Performance Tuning
MAX_WORKERS=4
REQUEST_TIMEOUT=30
CACHE_ENABLED=true
CACHE_TTL=3600

# Security
ENABLE_AUTH=false
API_KEY_REQUIRED=false
CORS_ENABLED=true

# Monitoring & Health
HEALTH_CHECK_INTERVAL=30
METRICS_ENABLED=true
PROMETHEUS_PORT=9090

# Subagent Configuration
SUBAGENT_1_LMS=http://south-lms:6000
SUBAGENT_2_API_GATEWAY=http://161:80
SUBAGENT_3_DATA_PROCESSOR=http://unruffled_buck:80
SUBAGENT_4_ANALYSIS=http://ecstatic_mirzakhani:80
SUBAGENT_5_ML_AI=http://magical_chaplygin:80

# Railway Specific (Optional)
RAILWAY_ENVIRONMENT=production
RAILWAY_TOKEN=${RAILWAY_TOKEN}
PROJECT_ID=${RAILWAY_PROJECT_ID}
